rules_version = '2';
// propertySales: apenas Cloud Functions (Admin SDK). Cliente: HTTPS clientPropertySalesMe / clientSaleEligibility.
// unit_status_overrides: leitura pública (sem PII); escrita só servidor.
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /clients/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /propertySales/{docId} {
      allow read, write: if false;
    }

    match /unit_status_overrides/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /repairRequests/{docId} {
      allow create: if request.resource.data.keys().hasAny(['description', 'clientId', 'clientEmail', 'propertyId']);
      allow read, update, delete: if true;
    }

    match /emailAuditLog/{docId} {
      allow create: if true;
      allow read: if isSignedIn();
    }

    match /emailQueue/{docId} {
      allow create: if true;
      allow read, update, delete: if isSignedIn();
    }

    match /chatbot_leads/{docId} {
      allow read, write: if isSignedIn();
    }

    match /chatbot_conversations/{phone}/{sub=**} {
      allow read: if isSignedIn();
    }

    match /chatbot_visits/{docId} {
      allow read, write: if isSignedIn();
    }

    match /site_visits/{docId} {
      allow create, read: if true;
      allow update, delete: if false;
    }

    match /brokers/{docId} {
      allow create: if request.resource.data.keys().hasAny(['email', 'name']);
      allow read, update, delete: if true;
    }

    match /passwordResetTokens/{docId} {
      allow create: if request.resource.data.keys().hasAny(['token', 'email']);
      allow read, update: if true;
    }

    // Campanha de corretores: manipulada apenas pelas Cloud Functions (Admin SDK).
    // Nenhum acesso direto pelo cliente.
    match /broker_campaign/{docId} {
      allow read, write: if false;
    }

    match /broker_campaign_logs/{docId} {
      allow read, write: if false;
    }
  }
}
