rules_version = '2';
// Dados sensíveis: apenas Cloud Functions (Admin SDK).
// Cliente/corretor/admin usam HTTPS endpoints autenticados.
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /clients/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /propertySales/{docId} {
      allow read, write: if false;
    }

    match /unit_status_overrides/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /repairRequests/{docId} {
      allow read, write: if false;
    }

    match /emailAuditLog/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    match /emailQueue/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    match /chatbot_leads/{docId} {
      allow read, write: if false;
    }

    match /chatbot_conversations/{phone}/{sub=**} {
      allow read, write: if false;
    }

    match /chatbot_visits/{docId} {
      allow read, write: if false;
    }

    match /site_visits/{docId} {
      allow create, read: if true;
      allow update, delete: if false;
    }

    match /brokers/{docId} {
      allow read, write: if false;
    }

    match /passwordResetTokens/{docId} {
      allow read, write: if false;
    }

    match /broker_campaign/{docId} {
      allow read, write: if false;
    }

    match /broker_campaign_logs/{docId} {
      allow read, write: if false;
    }

    match /boletos/{docId} {
      allow read, write: if false;
    }

    match /client_timeline/{docId} {
      allow read, write: if false;
    }

    match /reservations/{docId} {
      allow read, write: if false;
    }

    match /bia_training/{docId} {
      allow read, write: if false;
    }
  }
}
